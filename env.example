# Copy this file to ".env" for local development.
# Both values are public and safe to expose in client code (anon key).
# Get them from https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key-here

# PIN to access the admin dashboard (#admin route)
# Choose any short string. Default is 7777 if not set.
VITE_ADMIN_PIN=7777
